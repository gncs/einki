# einki environment — template for production.
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env && $EDITOR .env
#
# `.env` is gitignored so real secrets cannot be committed.

# Basic-auth credentials for the web UI.
EINKI_USERNAME=CHANGE_ME
EINKI_PASSWORD=CHANGE_ME

# Flask session signing key. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
EINKI_SECRET_KEY=CHANGE_ME

# DuckDNS dynamic DNS (only needed for HTTPS / prod deploys).
DUCKDNS_SUBDOMAIN=CHANGE_ME
DUCKDNS_TOKEN=CHANGE_ME
